{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/engine/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/app",        "destination": "/AlterCast.html" },
    { "source": "/studio",     "destination": "/AlterCast.html" },
    { "source": "/dashboard",  "destination": "/AlterCast.html" },
    { "source": "/settings",   "destination": "/AlterCast.html" },
    { "source": "/overlay",    "destination": "/AlterCast.html" },
    { "source": "/affiliate",  "destination": "/affiliate.html" },
    { "source": "/avatar",     "destination": "/avatar.html" },
    { "source": "/pure",       "destination": "/avatar.html" },
    { "source": "/avatar-live","destination": "/avatar.html" }
  ],
  "cleanUrls": true
}
